  "instruction": "Solve the inequality: {m}x + {b} < {rhs}. Express the answer as x < k.",
  "params": {
    "m": { "type": "int", "min": 1, "max": 6 },
    "b": { "type": "int", "min": -9, "max": 9 },
    "rhs": { "type": "int", "min": -9, "max": 9 }
  },
  "answer_expr": "linineq",
  "steps": [
    "Subtract {b} from both sides: {m}x < {rhs} - {b} = {diff}.",
    "Divide both sides by {m}: x < {diff} / {m} = {answer_linineq}."
  ],
  "tags": ["linear-inequality", "solving"]
}
