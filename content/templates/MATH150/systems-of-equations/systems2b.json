  "answer_expr": "systems2sub",
  "steps": [
    "Substitute y = {m}x + {b} into {p}x + {q}y = {r}.",
    "{p}x + {q}({m}x + {b}) = {r} => ({p} + {qm})x = {r} - {qb} => x = {answer_sys_x}.",
    "y = {m}({answer_sys_x}) + {b} = {answer_sys_y}."
