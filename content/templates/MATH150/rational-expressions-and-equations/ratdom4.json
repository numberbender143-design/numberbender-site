  "answer_expr": "ratdom4",
  "steps": [
    "Set each factor to zero.",
    "{den_c}x + {den_d} = 0 => x = {excl1}.",
    "{den_e}x + {den_f} = 0 => x = {excl2}.",
    "Excluded values: x = {excl1} and x = {excl2}."
