{"id":"prealg-percent_of-003","cid":"PREALG","topic":"Ratios, Proportions and Percents","subtopic":"Percent of a number","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"A store is offering a {p_pct}% discount on an item priced at ${n}. How many dollars is the discount?","params":{"p_pct":{"type":"int","min":10,"max":50},"n":{"type":"int","min":20,"max":200}},"answer_expr":"percent_of","steps":["Discount = {p_pct}% x ${n}.","Convert percent: {p_pct}/100 = decimal.","Discount = {p_pct} x {n} / 100 = ${answer_percent_of}."],"tags":["pre-algebra","percent","word-problem","discount"]}
