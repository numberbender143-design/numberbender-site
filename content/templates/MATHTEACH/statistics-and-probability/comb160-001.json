  "license": "CC BY-NC-SA (Numberbender original)",
  "instruction": "A committee of {r} people is to be chosen from a group of {n} people. Order does not matter. How many committees are possible?",
  "params": {
    "n": {
      "type": "int",
      "min": 7,
      "max": 15
    },
    "r": {
      "type": "int",
      "min": 2,
      "max": 4
    }
  },
  "answer_expr": "comb160",
  "steps": [
    "Order does not matter, so use combinations: C(n,r) = n!/(r!(n-r)!).",
    "C({n},{r}) = {n}!/({r}! * {n_minus_r}!) = {answer_comb160}."
  ],
