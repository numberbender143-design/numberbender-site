      "min": 2,
      "max": 6
    },
    "b": {
      "type": "int",
      "min": 10,
      "max": 40
    },
    "c": {
      "type": "int",
      "min": 4,
      "max": 12
    }
  },
  "answer_expr": "proportion",
  "steps": [
    "Set up the proportion: {a}/{b} = {c}/x.",
    "Cross-multiply: {a}x = {bc}.",
    "Divide both sides by {a}: x = {bc}/{a} = {answer_proportion}."
  ],
