{"id":"elmalg-slope-003","cid":"ELMALG","topic":"Graphing Lines","subtopic":"Slope from two points","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"A ramp rises from ({x1}, {y1}) to ({x2}, {y2}). Find the slope (rate of rise per horizontal unit).","params":{"x1":{"type":"int","min":0,"max":5},"y1":{"type":"int","min":0,"max":4},"dx":{"type":"int","min":2,"max":8},"dy":{"type":"int","min":1,"max":6}},"answer_expr":"slope","steps":["slope = rise / run = ({y2} - {y1}) / ({x2} - {x1}) = {rise} / {run}.","Slope = {answer_slope}."],"tags":["elementary-algebra","slope","two-points","word-problem"]}
