{"id":"elmalg-slope-001","cid":"ELMALG","topic":"Graphing Lines","subtopic":"Slope from two points","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Find the slope of the line passing through ({x1}, {y1}) and ({x2}, {y2}).","params":{"x1":{"type":"int","min":-4,"max":2},"y1":{"type":"int","min":-4,"max":4},"dx":{"type":"int","min":1,"max":6},"dy":{"type":"int","min":-6,"max":6}},"answer_expr":"slope","steps":["m = (y2 - y1)/(x2 - x1) = {rise}/{run} = {answer_slope}."],"tags":["elementary-algebra","slope","graphing"]}
