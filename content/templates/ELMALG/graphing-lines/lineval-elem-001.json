{"id":"elmalg-lineval-001","cid":"ELMALG","topic":"Graphing Lines","subtopic":"Evaluating linear functions","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"A line has equation f(x) = {m}x + {b}. Find f({x_val}).","params":{"m":{"type":"int","min":1,"max":6},"b":{"type":"int","min":-8,"max":8},"x_val":{"type":"int","min":-3,"max":6}},"answer_expr":"lineval","steps":["f({x_val}) = {m}({x_val}) + {b} = {m_times_x} + {b} = {answer_lineval}."],"tags":["elementary-algebra","linear-function","evaluate"]}
