{"id":"elmalg-polyfoil-002","cid":"ELMALG","topic":"Polynomials and Factoring","subtopic":"Multiplying polynomials (FOIL)","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Multiply using FOIL: ({a}x + {b})({c}x + {d})","params":{"a":{"type":"int","min":1,"max":4},"b":{"type":"int","min":1,"max":8},"c":{"type":"int","min":1,"max":4},"d":{"type":"int","min":1,"max":8}},"answer_expr":"polyfoil","steps":["First: {a}x * {c}x = {foil_a2}x^2.","Outer: {a}x * {d} = {foil_outer}x. Inner: {b} * {c}x = {foil_inner}x.","Last: {b} * {d} = {foil_c0}. Sum the middle terms: {foil_a1}x.","Result: {foil_a2}x^2 + {foil_a1}x + {foil_c0}."],"tags":["elementary-algebra","polynomials","FOIL","multiplication"]}
