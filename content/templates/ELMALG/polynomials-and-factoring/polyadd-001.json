{"id":"elmalg-polyadd-001","cid":"ELMALG","topic":"Polynomials and Factoring","subtopic":"Adding and subtracting polynomials","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Add: ({a1}x^2 + {b1}x + {c1}) + ({a2}x^2 + {b2}x + {c2})","params":{"a1":{"type":"int","min":1,"max":5},"b1":{"type":"int","min":1,"max":8},"c1":{"type":"int","min":1,"max":6},"a2":{"type":"int","min":1,"max":5},"b2":{"type":"int","min":1,"max":8},"c2":{"type":"int","min":1,"max":6}},"answer_expr":"polyadd","steps":["Combine like terms: ({a1}+{a2})x^2 = {ra}x^2, ({b1}+{b2})x = {rb}x, ({c1}+{c2}) = {rc}.","Result: {ra}x^2 + {rb}x + {rc}."],"tags":["elementary-algebra","polynomials","addition"]}
