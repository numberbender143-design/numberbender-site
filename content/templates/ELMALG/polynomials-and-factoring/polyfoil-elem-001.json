{"id":"elmalg-polyfoil-001","cid":"ELMALG","topic":"Polynomials and Factoring","subtopic":"Multiplying polynomials (FOIL)","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Multiply using FOIL: ({a}x + {b})({c}x + {d}).","params":{"a":{"type":"int","min":1,"max":3},"b":{"type":"int","min":1,"max":6},"c":{"type":"int","min":1,"max":3},"d":{"type":"int","min":1,"max":6}},"answer_expr":"polyfoil","steps":["F: {foil_a2}x^2. O: {foil_outer}x. I: {foil_inner}x. L: {foil_c0}.","Combine: {foil_a2}x^2 + {foil_a1}x + {foil_c0}."],"tags":["elementary-algebra","polynomial","FOIL"]}
