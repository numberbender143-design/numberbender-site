{"id":"math140-deriv_product210-dr001","cid":"MATH 140","topic":"Differentiation Rules","subtopic":"Product rule","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Revenue is R(x) = ({a}x + {b})({c}x + {d}). Use the product rule to find R'({x_val}).","params":{"a":{"type":"int","min":1,"max":5},"b":{"type":"int","min":1,"max":10},"c":{"type":"int","min":1,"max":5},"d":{"type":"int","min":1,"max":10},"x_val":{"type":"int","min":0,"max":4}},"answer_expr":"deriv_product210","steps":["u = {a}x+{b}, v = {c}x+{d}. u' = {a}, v' = {c}.","R'(x) = u'v + uv' = {a}({c}x+{d}) + {c}({a}x+{b}).","R'({x_val}) = {a}({v_at}) + {c}({u_at}) = {answer_deriv_product210}."],"tags":["business-calculus","product-rule","revenue","derivative"]}
