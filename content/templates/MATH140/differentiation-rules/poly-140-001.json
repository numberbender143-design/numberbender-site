{"id":"math140-deriv_poly210-dr001","cid":"MATH 140","topic":"Differentiation Rules","subtopic":"Differentiating polynomials","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Total revenue is R(x) = {pa}x^3 + {pb}x^2 + {pc}x + {pd}. Find the marginal revenue MR = R'({x_val}).","params":{"pa":{"type":"int","min":1,"max":2},"pb":{"type":"int","min":-4,"max":0},"pc":{"type":"int","min":10,"max":30},"pd":{"type":"int","min":0,"max":100},"x_val":{"type":"int","min":1,"max":3}},"answer_expr":"deriv_poly210","steps":["MR = R'(x) = {da}x^2 + {db}x + {dc}.","R'({x_val}) = {da}({x_val})^2 + {db}({x_val}) + {dc} = {answer_deriv_poly210}."],"tags":["business-calculus","marginal-revenue","polynomial","derivative"]}
