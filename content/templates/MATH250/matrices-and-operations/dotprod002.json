    "u3": { "type": "int", "min": -4, "max": 4 },
    "v1": { "type": "int", "min": -4, "max": 4 },
    "v2": { "type": "int", "min": -4, "max": 4 },
    "v3": { "type": "int", "min": -4, "max": 4 }
  },
  "answer_expr": "dotprod250",
  "steps": [
    "u dot v = u1*v1 + u2*v2 + u3*v3 = {u1}*{v1} + {u2}*{v2} + {u3}*{v3} = {answer_dotprod250}."
