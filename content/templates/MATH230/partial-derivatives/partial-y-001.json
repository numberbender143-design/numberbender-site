{"id":"math230-partial_y230-001","cid":"MATH 230","topic":"Partial Derivatives","subtopic":"Partial derivatives","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Let f(x,y) = {a}x^{m}y^{n}. Find the partial derivative f_y({x0},{y0}).","params":{"a":{"type":"int","min":1,"max":5},"m":{"type":"int","min":1,"max":3},"n":{"type":"int","min":2,"max":3},"x0":{"type":"int","min":1,"max":3},"y0":{"type":"int","min":1,"max":3}},"answer_expr":"partial_y230","steps":["Differentiate with respect to y, treating x as constant.","f_y = {coeff_y}x^{m}y^{new_n}.","f_y({x0},{y0}) = {coeff_y}·{x0}^{m}·{y0}^{new_n} = {answer_partial_y230}."],"tags":["calculus-3","partial-derivative","multivariable"]}
