{"id":"math230-partial_x230-001","cid":"MATH 230","topic":"Partial Derivatives","subtopic":"Partial derivatives","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Let f(x,y) = {a}x^{m}y^{n}. Find the partial derivative f_x({x0},{y0}).","params":{"a":{"type":"int","min":1,"max":5},"m":{"type":"int","min":2,"max":3},"n":{"type":"int","min":1,"max":3},"x0":{"type":"int","min":1,"max":3},"y0":{"type":"int","min":1,"max":3}},"answer_expr":"partial_x230","steps":["Differentiate with respect to x, treating y as constant.","f_x = {coeff_x}x^{new_m}y^{n}.","f_x({x0},{y0}) = {coeff_x}·{x0}^{new_m}·{y0}^{n} = {answer_partial_x230}."],"tags":["calculus-3","partial-derivative","multivariable"]}
