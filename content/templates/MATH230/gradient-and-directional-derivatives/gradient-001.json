{"id":"math230-partial_x230-grad001","cid":"MATH 230","topic":"Gradient and Directional Derivatives","subtopic":"Computing gradient components","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"For f(x,y) = {a}x^{m}y^{n}, compute f_x({x0},{y0}) — the x-component of the gradient at ({x0},{y0}).","params":{"a":{"type":"int","min":1,"max":4},"m":{"type":"int","min":2,"max":3},"n":{"type":"int","min":1,"max":2},"x0":{"type":"int","min":1,"max":3},"y0":{"type":"int","min":1,"max":3}},"answer_expr":"partial_x230","steps":["Gradient = (f_x, f_y). Find x-component: f_x = {coeff_x}x^{new_m}y^{n}.","f_x({x0},{y0}) = {answer_partial_x230}.","This is the x-component of ∇f at ({x0},{y0})."],"tags":["calculus-3","gradient","directional-derivative"]}
