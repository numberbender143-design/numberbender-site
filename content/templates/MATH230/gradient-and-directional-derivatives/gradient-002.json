{"id":"math230-partial_y230-grad001","cid":"MATH 230","topic":"Gradient and Directional Derivatives","subtopic":"Computing gradient components","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"For f(x,y) = {a}x^{m}y^{n}, compute f_y({x0},{y0}) — the y-component of the gradient at ({x0},{y0}).","params":{"a":{"type":"int","min":1,"max":4},"m":{"type":"int","min":1,"max":2},"n":{"type":"int","min":2,"max":3},"x0":{"type":"int","min":1,"max":3},"y0":{"type":"int","min":1,"max":3}},"answer_expr":"partial_y230","steps":["Gradient = (f_x, f_y). Find y-component: f_y = {coeff_y}x^{m}y^{new_n}.","f_y({x0},{y0}) = {answer_partial_y230}.","This is the y-component of ∇f at ({x0},{y0})."],"tags":["calculus-3","gradient","directional-derivative"]}
