{"id":"math230-dot_prod230-002","cid":"MATH 230","topic":"Vectors in 3D","subtopic":"Dot product","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Force vector F = ({a1}, {a2}, {a3}) N acts on a displacement d = ({b1}, {b2}, {b3}) m. Compute the work W = F · d.","params":{"a1":{"type":"int","min":1,"max":6},"a2":{"type":"int","min":1,"max":6},"a3":{"type":"int","min":1,"max":6},"b1":{"type":"int","min":1,"max":5},"b2":{"type":"int","min":1,"max":5},"b3":{"type":"int","min":1,"max":5}},"answer_expr":"dot_prod230","steps":["W = F · d = ({a1})({b1}) + ({a2})({b2}) + ({a3})({b3}) = {answer_dot_prod230} J."],"tags":["calculus-3","vectors","dot-product","work","application"]}
