{"id":"math230-dot_prod230-vc001","cid":"MATH 230","topic":"Line Integrals and Vector Calculus","subtopic":"Work along a path","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"A vector field F = ({a1}, {a2}, {a3}) acts along a straight path with displacement vector d = ({b1}, {b2}, {b3}). Find the work done W = F · d.","params":{"a1":{"type":"int","min":-5,"max":5},"a2":{"type":"int","min":-5,"max":5},"a3":{"type":"int","min":0,"max":3},"b1":{"type":"int","min":1,"max":6},"b2":{"type":"int","min":1,"max":6},"b3":{"type":"int","min":0,"max":2}},"answer_expr":"dot_prod230","steps":["W = F · d = ({a1})({b1}) + ({a2})({b2}) + ({a3})({b3}) = {answer_dot_prod230}."],"tags":["calculus-3","work","line-integral","dot-product"]}
