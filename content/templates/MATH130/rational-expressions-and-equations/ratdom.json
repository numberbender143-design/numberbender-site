      "type": "int",
      "min": 1,
      "max": 5
    },
    "den_d": {
      "type": "int",
      "min": -9,
      "max": 9
    }
  },
  "answer_expr": "ratdom",
  "steps": [
    "Set denominator = 0: {den_c}x + {den_d} = 0 => x = {answer_ratdom}.",
