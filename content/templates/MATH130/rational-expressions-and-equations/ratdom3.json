  "instruction": "Simplify the rational expression: ({a}x + {ab}) / ({a}x + {ac}). Find the excluded value and the simplified form.",
  "params": {
    "a": {
      "type": "int",
      "min": 1,
      "max": 4
    },
    "b": {
      "type": "int",
      "min": 1,
      "max": 6
    },
    "c": {
      "type": "int",
      "min": 1,
      "max": 6
    }
  },
  "answer_expr": "ratsimp",
  "steps": [
    "Factor: {a}(x + {b}) / {a}(x + {c}).",
    "Cancel the common factor {a}: (x + {b}) / (x + {c}).",
    "Excluded value: x = -{c} (denominator = 0)."
  ],
  "tags": [
    "rational-expression",
    "simplify",
    "factoring"
  ]
}