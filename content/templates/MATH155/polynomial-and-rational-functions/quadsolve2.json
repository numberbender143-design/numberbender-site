  "instruction": "Use the quadratic formula to solve x^2 + {b_coef}x + {c_coef} = 0 (a = 1, roots are integers).",
  "params": {
    "root1": { "type": "int", "min": -5, "max": -1 },
    "root2": { "type": "int", "min": 1, "max": 5 },
    "a": { "type": "int", "min": 1, "max": 1 }
  },
  "answer_expr": "quadsolve",
  "steps": [
    "Identify: a = 1, b = {b_coef}, c = {c_coef}.",
    "Discriminant: b^2 - 4ac = ({b_coef})^2 - 4(1)({c_coef}) = {disc}.",
    "x = (-{b_coef} +/- sqrt({disc})) / 2 = ({neg_b} +/- {sqrt_disc}) / 2.",
    "x = {answer_q1} or x = {answer_q2}."
  ],
