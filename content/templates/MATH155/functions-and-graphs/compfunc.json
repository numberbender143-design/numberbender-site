{
  "id": "math155-compfunc-001",
  "cid": "MATH 155",
  "topic": "Functions and Graphs",
  "subtopic": "Function composition",
  "difficulty": 2,
  "license": "CC BY-NC-SA (Numberbender original)",
  "instruction": "Let f(x) = {a}x + {b} and g(x) = {c}x + {d}. Find (f composed with g)({x_val}), i.e., f(g({x_val})).",
  "params": {
    "a": { "type": "int", "min": 1, "max": 5 },
    "b": { "type": "int", "min": -5, "max": 5 },
    "c": { "type": "int", "min": 1, "max": 5 },
    "d": { "type": "int", "min": -5, "max": 5 },
    "x_val": { "type": "int", "min": -3, "max": 3 }
  },
  "answer_expr": "compfunc",
  "steps": [
    "First compute g({x_val}) = {c}({x_val}) + {d} = {g_of_x}.",
    "Then compute f(g({x_val})) = f({g_of_x}) = {a}({g_of_x}) + {b} = {answer_compfunc}."
  ],
  "tags": ["composition", "function-operations"]
}
