  "instruction": "Given f(x) = {m}x + {b}, find f^{{-1}}({y_val}). That is, find x such that f(x) = {y_val}.",
  "params": {
    "m": { "type": "int", "min": 1, "max": 6 },
    "b": { "type": "int", "min": -6, "max": 6 },
    "t": { "type": "int", "min": -4, "max": 4 }
  },
  "answer_expr": "invfunc",
  "steps": [
    "Set f(x) = {y_val}: {m}x + {b} = {y_val}.",
    "Subtract {b}: {m}x = {y_val} - {b} = {numer}.",
    "Divide by {m}: x = {numer} / {m} = {answer_invfunc}."
