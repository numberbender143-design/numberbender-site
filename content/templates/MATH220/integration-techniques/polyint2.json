  "answer_expr": "polyint2",
  "steps": [
    "Antiderivative of {c}x^{n} is {c}x^({n}+1)/({n}+1) = {coef_str}x^{n_plus_1}.",
    "Evaluate at {b}: {coef_str}*{b}^{n_plus_1} = {upper_val}.",
    "Evaluate at {a}: {coef_str}*{a}^{n_plus_1} = {lower_val}.",
    "Result: {upper_val} - {lower_val} = {answer_polyint2}."
