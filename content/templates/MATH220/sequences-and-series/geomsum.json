{
  "id": "math220-geomsum-001",
  "cid": "MATH 220",
  "topic": "Sequences and Series",
  "subtopic": "Geometric series — partial sum",
  "difficulty": 2,
  "license": "CC BY-NC-SA (Numberbender original)",
  "instruction": "Find the sum of the first {n_terms} terms of the geometric series with a_1 = {a1} and r = {r}.",
  "params": {
    "a1": { "type": "int", "min": 1, "max": 4 },
    "r":  { "type": "int", "min": 2, "max": 4 },
    "n_terms": { "type": "int", "min": 3, "max": 6 }
  },
  "answer_expr": "geomsum",
  "steps": [
    "Use S_n = a_1 * (1 - r^n) / (1 - r).",
    "S_{n_terms} = {a1} * (1 - {r}^{n_terms}) / (1 - {r}).",
    "= {a1} * (1 - {r_pow}) / {one_minus_r} = {a1} * {numer_g} / {one_minus_r} = {answer_geomsum}."
  ],
  "tags": ["geometric-series", "partial-sum", "sigma"]
}
