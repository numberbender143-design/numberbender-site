{"id":"math120-defint210-001","cid":"MATH 120","topic":"Antiderivatives and Integrals","subtopic":"Definite integrals","difficulty":2,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Evaluate the definite integral: integral from {lo} to {hi} of x^{n} dx.","params":{"n":{"type":"int","min":1,"max":3},"lo":{"type":"int","min":0,"max":2},"hi":{"type":"int","min":2,"max":5}},"answer_expr":"defint210","steps":["FTC: integral from {lo} to {hi} of x^{n} dx = [x^{n+1}/({n+1})] from {lo} to {hi}.","= ({hi_pow} - {lo_pow}) / {n+1} = {answer_defint210}."],"tags":["survey-calculus","definite-integral","FTC"]}
