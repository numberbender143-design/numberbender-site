{
  "id": "math210-deriv_chain210-001",
  "cid": "MATH 210",
  "topic": "Derivatives Rules",
  "subtopic": "Chain rule",
  "difficulty": 2,
  "license": "CC BY-NC-SA (Numberbender original)",
  "instruction": "Let f(x) = ({a}x + {b})^{n}. Use the chain rule to find f'({x_val}).",
  "params": {
    "a": {
      "type": "int",
      "min": 1,
      "max": 4
    },
    "b": {
      "type": "int",
      "min": -3,
      "max": 3
    },
    "n": {
      "type": "int",
      "min": 2,
      "max": 4
    },
    "x_val": {
      "type": "int",
      "min": -1,
      "max": 3
    }
  },
  "answer_expr": "deriv_chain210",
  "steps": [
    "Chain rule: f'(x) = {n}({a}x+{b})^{n-1} * {a}.",
    "Inner function at x={x_val}: {a}({x_val})+{b} = {inner}.",
    "f'({x_val}) = {n}*{a}*({inner})^{n-1} = {n}*{a}*{inner_pow} = {answer_deriv_chain210}."
  ],
  "tags": [
    "calculus",
    "chain-rule",
    "composite"
  ]
}