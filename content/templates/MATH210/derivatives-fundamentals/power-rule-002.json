  "instruction": "The position of a particle is s(t) = {a}t^{n} meters. Find the velocity s'({c_val}) at t = {c_val} seconds.",
  "params": {
    "a": {
      "type": "int",
      "min": 1,
      "max": 4
    },
    "n": {
      "type": "int",
      "min": 2,
      "max": 4
    },
    "c_val": {
      "type": "int",
      "min": 1,
      "max": 3
    }
  },
  "answer_expr": "deriv_power210",
  "steps": [
    "Velocity = s'(t) = {coeff}t^{new_exp}.",
    "At t = {c_val}: s'({c_val}) = {coeff}({c_val})^{new_exp} = {answer_deriv_power210} m/s."
  ],
