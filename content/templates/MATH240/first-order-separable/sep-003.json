{"id":"math240-antideriv210-sep003","cid":"MATH 240","topic":"First Order Separable","subtopic":"Separable ODEs","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Solve: dy/dx = {a}x^{n}. Then find the particular solution satisfying y(0) = 0.","params":{"a":{"type":"int","min":2,"max":8},"n":{"type":"int","min":1,"max":3}},"answer_expr":"antideriv210","steps":["Integrate: y = {answer_antideriv210}x^{new_exp210} + C.","Apply y(0)=0: 0 = 0 + C, so C = 0.","Particular solution: y = {answer_antideriv210}x^{new_exp210}."],"tags":["ode","separable","IVP","initial-value"]}
