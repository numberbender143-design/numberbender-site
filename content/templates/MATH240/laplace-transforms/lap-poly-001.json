{"id":"math240-laplace_poly240-001","cid":"MATH 240","topic":"Laplace Transforms","subtopic":"Laplace transform of power functions","difficulty":1,"license":"CC BY-NC-SA (Numberbender original)","instruction":"Find the Laplace transform of f(t) = {a}*t^{n}.","params":{"a":{"type":"int","min":1,"max":5},"n":{"type":"int","min":0,"max":3}},"answer_expr":"laplace_poly240","steps":["Formula: L[t^n] = n! / s^(n+1).","L[{a}*t^{n}] = {a}*{nfact} / s^{exp_p1} = {coeff} / s^{exp_p1}.","Numerator coefficient: {answer_laplace_poly240}."],"tags":["ode","Laplace","transform","polynomial"]}
