# Netlify Redirects — numberbender.com
# Old CMS platform URLs → new static site

# Homepage aliases
/home                           /                               301
/index                          /                               301
/index.html                     /                               301

# Worksheets hub aliases → printable worksheet library landing page
/worksheets                     /math-worksheets                301
/math-worksheets.html           /math-worksheets                301
/free-worksheets                /math-worksheets                301
/printable-worksheets           /math-worksheets                301

# Hub canonical = /courses. The v2 hub content now lives at courses.html, served
# at /courses (netlify.toml: /courses.html -> /courses). The old courses-v2.html
# filename is retired — send any old/bookmarked links to the canonical hub.
/courses-v2.html                /courses                        301
/courses-v2                     /courses                        301

# Old lesson/topic URLs → canonical hub
# NOTE: do NOT add a /subjects/* rule — /subjects/ is now a real v2 directory
# tree (the subject library). A glob there would shadow real pages and can
# cause Google to deindex them. Same caution applies to /courses/* (worksheet hubs).
/lessons/*                      /courses                        301
/topics/*                       /courses                        301

# Old uploads/attachments → homepage
/uploads/*                      /                               301
/attachments/*                  /                               301

# Old user/profile URLs
/users/*                        /about.html                     301
/profile/*                      /about.html                     301

# Old blog/post URLs → blog
/posts/*                        /blog.html                      301
/blog/posts/*                   /blog.html                      301
/news/*                         /blog.html                      301

# Old contact/about URLs
/contact-us                     /contact.html                   301
/about-us                       /about.html                     301

# Trailing slash normalization (Netlify handles this, but just in case)
/courses/                       /courses                        301
/about/                         /about.html                     301
/contact/                       /contact.html                   301
/blog/                          /blog.html                      301
/speaking/                      /speaking.html                  301

# Catch-all: anything else not found → custom 404 (Netlify does this automatically via 404.html)
