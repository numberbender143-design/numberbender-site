# Local Netlify folder
.netlify

# macOS
.DS_Store
**/.DS_Store

# Python build scripts (not site content)
*.py

# Spreadsheet working files
*.xlsx
*.pages

# Claude workspace
.claude/

# macOS FUSE temp files
.fuse_hidden*

# ZIP bundles (hosted on Google Drive, not Netlify)
bundles/*.zip

# ------------------------------------------------------------
# Internal planning docs & working data — must NOT be deployed
# publicly (publish root = repo root, so anything committed is
# reachable at numberbender.com/<filename>).
# ------------------------------------------------------------
*.md
*.docx
*.csv
*.command
*.sh

# Large internal data dump (the SITE itself only fetches
# /worksheet-index.json at runtime — that file is kept.)
yt_inventory.json

# Archive folder — holding pen for non-deployment files (docs, data,
# scripts, spreadsheets, old reports). Never deploy this to Netlify.
_archive/

# Audit deliverables (reports, patches) — review artifacts, not site content
numberbender audit/
*.patch

# Editor / build junk
__pycache__/
.~lock.*

# Internal creative/brand assets — not part of the deployed site
BLOG_VIDEO_POST/
School_logo/

# v3.0 development folder — not ready for deployment
numberbender v3.0/

# Dev validator (run locally before deploy; not site content)
tools/validate-pages.js

# stray test bank (cannot delete from sandbox; never deploy)
content/banks/_TEST_*.js
